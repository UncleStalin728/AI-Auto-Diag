{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "api",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "uvicorn", "app.main:app", "--host", "127.0.0.1", "--reload"],
      "port": 8000
    },
    {
      "name": "ui",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "streamlit", "run", "ui/streamlit_app.py", "--server.headless", "true", "--server.port", "8502"],
      "port": 8502
    }
  ]
}
